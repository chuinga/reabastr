<?xml version="1.0" encoding="utf-8"?>
<!--
  Reabastr brand logo: a line-art house outline with a peaked roof, a central
  door, and a small corner flag on the right roof slope. Drawn with strokes only
  (transparent fill) and a white stroke so it can be tinted to any theme color.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Roof -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M28,52 L54,30 L80,52" />

    <!-- Corner flag on the right roof slope -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M62,33 L68,33 L68,40" />

    <!-- House body: left wall, floor, right wall -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M33,50 L33,82 L75,82 L75,50" />

    <!-- Door -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M47,82 L47,63 L61,63 L61,82" />
</vector>
